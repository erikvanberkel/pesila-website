{# Responsive Picture Component
   Usage: {% for img in gallery %}{% include "picture.njk" %}{% endfor %}
   Expects: img object with number, orientation, alt
#}
<picture class="{{ img.orientation }}">
  <source media="(min-width: 1200px)" srcset="/images/gallery/w1920/photo-{{ img.number }}.avif" type="image/avif" />
  <source media="(min-width: 768px)" srcset="/images/gallery/w1280/photo-{{ img.number }}.avif" type="image/avif" />
  <source media="(min-width: 320px)" srcset="/images/gallery/w640/photo-{{ img.number }}.avif" type="image/avif" />
  <source media="(max-width: 319px)" srcset="/images/gallery/w320/photo-{{ img.number }}.avif" type="image/avif" />
  <source media="(min-width: 1200px)" srcset="/images/gallery/w1920/photo-{{ img.number }}.webp" type="image/webp" />
  <source media="(min-width: 768px)" srcset="/images/gallery/w1280/photo-{{ img.number }}.webp" type="image/webp" />
  <source media="(min-width: 320px)" srcset="/images/gallery/w640/photo-{{ img.number }}.webp" type="image/webp" />
  <source media="(max-width: 319px)" srcset="/images/gallery/w320/photo-{{ img.number }}.webp" type="image/webp" />
  <img src="/images/gallery/w640/photo-{{ img.number }}.webp" alt="{{ img.alt }}" class="{{ img.orientation }}" loading="lazy" />
</picture>
