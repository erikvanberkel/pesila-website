{# Service Card Component
   Usage: {% for service in services %}{% include "service-card.njk" %}{% endfor %}
   Expects: service object with id, name, image, alt, description, pricing array
#}
<div class="col-xl-4 col-md-6 mb-4">
  <article class="service-card" tabindex="0" role="button" aria-expanded="false" aria-labelledby="{{ service.id }}">
    <img src="/images/services/{{ service.image }}" loading="lazy" alt="{{ service.alt }}" />
    <h3 id="{{ service.id }}">{{ service.name | safe }}</h3>
    <div class="text-container">
      <div>
        {{ service.description | safe }}
      </div>
    </div>
    <div class="pricing-table">
      <table aria-label="Prijzen voor {{ service.nameClean or service.name | striptags }}">
        <tr>
          <th scope="col">Duur</th>
          <th scope="col">Prijs</th>
        </tr>
        {%- for price in service.pricing -%}
        <tr>
          <td>{{ price.duration }}</td>
          <td>{{ price.price }}</td>
        </tr>
        {%- endfor -%}
      </table>
    </div>
  </article>
</div>
