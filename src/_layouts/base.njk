<!DOCTYPE html>
<html lang="nl">
  <head>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-69BZRSS6JF"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-69BZRSS6JF");
    </script>
    {% block head_early %}{% endblock %}
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title }} | Pesila Thai Massage Rotterdam</title>
    <meta name="description" content="{{ description }}" />
    {% if keywords %}<meta name="keywords" content="{{ keywords }}" />{% endif %}
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Pesila Thai Massage" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" as="style" preload />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&family=DM+Sans:wght@400;500;600&display=swap"
      as="style"
      preload
    />
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="icon" type="image/png" href="/images/icon.png" />
    {% if canonical %}<link rel="canonical" href="{{ canonical }}" />{% endif %}
    {% block og_tags %}{% endblock %}
    {% block head %}{% endblock %}
    <noscript>
      <style>
        #preloader {
          display: none !important;
        }
      </style>
    </noscript>
  </head>
  <body>
    {% include "nav.njk" %}

    {% block preloader %}{% endblock %}

    <main>
      <div id="main-content"></div>
      {{ content | safe }}
    </main>

    {% include "footer.njk" %}

    {% block scripts %}{% endblock %}
  </body>
</html>
