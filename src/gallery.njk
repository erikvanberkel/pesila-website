---
layout: base.njk
title: Gallerij
description: Bekijk foto's van Pesila Thai Massage in Rotterdam - onze behandelkamers, interieur en sfeerbeelden.
permalink: /gallery/index.html
---

{% block head %}
<style>
  body.no-scroll {
    overflow: hidden;
  }

  .skip-link {
    position: absolute;
    top: -40px;
    left: 0;
    background: #6b4e31;
    color: white;
    padding: 8px 16px;
    text-decoration: none;
    z-index: 10000;
    border-radius: 0 0 4px 0;
  }

  .skip-link:focus {
    top: 0;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 2rem;
    margin: 0 auto;
  }

  .gallery img,
  .gallery picture {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8px;
    cursor: pointer;
    transition: var(--transition);
  }

  .gallery img:hover {
    transform: scale(1.025);
    box-shadow: 0 0 16px rgba(0, 0, 0, 0.5);
  }

  .landscape {
    grid-column: span 2 / auto;
  }

  .portrait {
    grid-column: span 2 / auto;
    grid-row: span 2 / auto;
  }

  .fullscreen-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    height: 100dvh;
    background-color: #000;
    justify-content: center;
    align-items: center;
    z-index: 1040;
  }

  .fullscreen-modal img {
    max-width: 90%;
    max-height: 90%;
    object-fit: contain;
    border-radius: 8px;
  }

  .close-button {
    position: absolute;
    top: 20px;
    right: 20px;
    font-size: 40px;
    color: white;
    cursor: pointer;
    background: none;
    border: none;
  }

  @media (max-width: 600px) {
    .gallery {
      grid-template-columns: 1fr;
    }
  }
</style>
{% endblock %}

<section aria-labelledby="gallery-heading">
  <div class="container">
    <h2 id="gallery-heading" class="section-title">Gallerij</h2>
    <div class="gallery">
      {%- for img in gallery -%}
        {% include "picture.njk" %}
      {%- endfor -%}
    </div>
  </div>
</section>

<div class="fullscreen-modal" id="fullscreenModal" role="dialog" aria-modal="true" aria-label="Vergroot afbeelding">
  <button class="close-button" id="closeButton" aria-label="Sluit galerij">&times;</button>
  <img id="fullscreenImage" src="" alt="" />
</div>

{% block scripts %}
<script>
  const galleryImages = document.querySelectorAll(".gallery img");
  const fullscreenModal = document.getElementById("fullscreenModal");
  const fullscreenImage = document.getElementById("fullscreenImage");
  const closeButton = document.getElementById("closeButton");
  const body = document.body;
  let lastFocusedElement = null;

  function openModal(image) {
    lastFocusedElement = document.activeElement;
    fullscreenImage.src = image.src.replace(/w\d+/, 'w1920');
    fullscreenImage.alt = image.alt;
    fullscreenModal.style.display = "flex";
    body.classList.add("no-scroll");
    closeButton.focus();
  }

  function closeModal() {
    fullscreenModal.style.display = "none";
    body.classList.remove("no-scroll");
    if (lastFocusedElement) {
      lastFocusedElement.focus();
    }
  }

  galleryImages.forEach((image) => {
    image.addEventListener("click", () => openModal(image));
  });

  closeButton.addEventListener("click", closeModal);

  fullscreenModal.addEventListener("click", (e) => {
    if (e.target === fullscreenModal) {
      closeModal();
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && fullscreenModal.style.display === "flex") {
      closeModal();
    }
  });

  fullscreenModal.addEventListener("keydown", (e) => {
    if (e.key === "Tab") {
      const focusableElements = fullscreenModal.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');
      const firstElement = focusableElements[0];
      const lastElement = focusableElements[focusableElements.length - 1];

      if (e.shiftKey && document.activeElement === firstElement) {
        e.preventDefault();
        lastElement.focus();
      } else if (!e.shiftKey && document.activeElement === lastElement) {
        e.preventDefault();
        firstElement.focus();
      }
    }
  });
</script>
{% endblock %}
